APP_ENV=local
DATABASE_URL=sqlite:///./foyre.db

AUTH_PROVIDER=local
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=480

# Fernet key used to encrypt sensitive fields at rest (host-cluster
# kubeconfigs, generated user kubeconfigs). Generate a fresh one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Changing this key makes previously-encrypted values unreadable.
APP_SECRET_KEY=change-me-to-a-fernet-key

SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin
SEED_ADMIN_EMAIL=admin@example.com
